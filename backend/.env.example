# Encryption key for database tokens (64-char hex = 32 bytes for AES-256-GCM)
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Path to the control plane SQLite database
DATABASE_FILE=./data/control.db

# Server port
PORT=3000

# Allowed CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3001

# Root path where managed SQLite files are stored
SQLITE_STORAGE_ROOT=./data/sqlite

# Path to scan for existing .db files
SQLITE_DISCOVERY_PATH=./data/sqlite

# Project ID to assign to discovered databases (leave empty to disable auto-discovery)
SQLITE_DISCOVERY_PROJECT_ID=

# Whether to copy discovered files into managed storage
SQLITE_DISCOVERY_ADOPT=false

# Template used to generate the user-facing database connection URL.
# Supported placeholders: {subdomain}, {name}, {id}, {slug}
# Example for a path-based public endpoint:
# DATABASE_PUBLIC_URL_TEMPLATE=http://192.168.100.100:8081/{subdomain}
DATABASE_PUBLIC_URL_TEMPLATE=
